  "rows": [
    {
      "$id": 1,
      "label": "xs32110100_MSG0005",
      "style": 0,
      "name": ""
    },
    {
      "$id": 2,
      "label": "xs32110100_MSG0010",
      "style": 0,
      "name": "So many different races helping each other[ST:wide ]―[ST:wait ]"
    },
    {
      "$id": 3,
      "label": "xs32110100_MSG0020",
      "style": 0,
      "name": "Mira really is a warm place[ST:wide ]―[ST:wait ]"
    },
    {
      "$id": 4,
      "label": "xs32110100_MSG0030",
      "style": 0,
      "name": "Just like Lao said.[ST:wait ]"
    },
    {
      "$id": 5,
      "label": "xs32110100_MSG0040",
      "style": 0,
      "name": "Lao...san?[ST:wait ]"
    },
    {
      "$id": 6,
      "label": "xs32110100_MSG0050",
      "style": 0,
      "name": "Al, did you[ST:wide ]―[ST:wait ]"
    },
    {
      "$id": 7,
      "label": "xs32110100_MSG0060",
      "style": 0,
      "name": "You met Lao?[ST:wait ]"
    },
    {
      "$id": 8,
      "label": "xs32110100_MSG0070",
      "style": 0,
      "name": "When[ST:wide ]―[ST:wait ]"
    },
    {
      "$id": 9,
      "label": "xs32110100_MSG0080",
      "style": 0,
      "name": "While I was drifting through\nthe rift between worlds.[ST:wait ]"
    },
    {
      "$id": 10,
      "label": "xs32110100_MSG0090",
      "style": 0,
      "name": "Could it be[ST:wide ]―[ST:wait ]"
    },
    {
      "$id": 11,
      "label": "xs32110100_MSG0100",
      "style": 0,
      "name": "What some religions call[ST:wait ]"
    },
    {
      "$id": 12,
      "label": "xs32110100_MSG0110",
      "style": 0,
      "name": "\"Nirvana\"... perhaps that\nplace was something like it.[ST:wait ]"
    },
    {
      "$id": 13,
      "label": "xs32110100_MSG0120",
      "style": 0,
      "name": "Drifting through the rift,\nguided by the Ares,[ST:wait ]"
    },
    {
      "$id": 14,
      "label": "xs32110100_MSG0130",
      "style": 0,
      "name": "as I searched for a way\nto return to this world[ST:wide ]―[ST:wait ]"
    },
    {
      "$id": 15,
      "label": "xs32110100_MSG0140",
      "style": 0,
      "name": "I stumbled upon a strange\nplace along the way.[ST:wait ]"
    },
    {
      "$id": 16,
      "label": "xs32110100_MSG0150",
      "style": 0,
      "name": "Fancy meeting you in a weird place like this.[ST:wait ]"
    },
    {
      "$id": 17,
      "label": "xs32110100_MSG0160",
      "style": 0,
      "name": "Al[ST:wide ]―[ST:wait ]"
    },
    {
      "$id": 18,
      "label": "xs32110100_MSG0170",
      "style": 0,
      "name": "I think the last time we spoke directly\nwas when I left Ohime-sama's team.[ST:wait ]"
    },
    {
      "$id": 19,
      "label": "xs32110100_MSG0180",
      "style": 0,
      "name": "I was sure you'd died in the battle\nbefore the White Whale crashed on Mira.[ST:wait ]"
    },
    {
      "$id": 20,
      "label": "xs32110100_MSG0190",
      "style": 0,
      "name": "Well, if you call this the\nafterlife, then you're right.[ST:wait ]"
    },
    {
      "$id": 21,
      "label": "xs32110100_MSG0200",
      "style": 0,
      "name": "[ST:wide ]―So, what about you?[ST:wait ]"
    },
    {
      "$id": 22,
      "label": "xs32110100_MSG0210",
      "style": 0,
      "name": "Are you dead?[ST:wait ]"
    },
    {
      "$id": 23,
      "label": "xs32110100_MSG0220",
      "style": 0,
      "name": "Yeah[ST:wide ]―[ST:wait ]"
    },
    {
      "$id": 24,
      "label": "xs32110100_MSG0230",
      "style": 0,
      "name": "Figured.[ST:wait ]"
    },
    {
      "$id": 25,
      "label": "xs32110100_MSG0240",
      "style": 0,
      "name": "I[ST:wide ]―[ST:wait ]"
    },
    {
      "$id": 26,
      "label": "xs32110100_MSG0250",
      "style": 0,
      "name": "I betrayed my comrades.[ST:wait ]"
    },
    {
      "$id": 27,
      "label": "xs32110100_MSG0260",
      "style": 0,
      "name": "Sold information to the enemy, to get\nrevenge on those who left my family to die[ST:wide ]―[ST:wait ]"
    },
    {
      "$id": 28,
      "label": "xs32110100_MSG0270",
      "style": 0,
      "name": "No.[ST:wait ]"
    },
    {
      "$id": 29,
      "label": "xs32110100_MSG0280",
      "style": 0,
      "name": "I tried to erase everything.[ST:wait ]"
    },
    {
      "$id": 30,
      "label": "xs32110100_MSG0290",
      "style": 0,
      "name": "More than superficial emotions like mourning\nor giving them what they deserve...[ST:wait ]"
    },
    {
      "$id": 31,
      "label": "xs32110100_MSG0300",
      "style": 0,
      "name": "A despair far deeper than that[ST:wait ]"
    },
    {
      "$id": 32,
      "label": "xs32110100_MSG0305",
      "style": 0,
      "name": "drove me out of control.[ST:wait ]"
    },
    {
      "$id": 33,
      "label": "xs32110100_MSG0310",
      "style": 0,
      "name": "I knew it[ST:wide ]―[ST:wait ]"
    },
    {
      "$id": 34,
      "label": "xs32110100_MSG0320",
      "style": 0,
      "name": "I knew it, but[ST:wait ]"
    },
    {
      "$id": 35,
      "label": "xs32110100_MSG0330",
      "style": 0,
      "name": "I couldn't stop.[ST:wait ]"
    },
    {
      "$id": 36,
      "label": "xs32110100_MSG0340",
      "style": 0,
      "name": "You're sounding like you're full of excuses.[ST:wait ]"
    },
    {
      "$id": 37,
      "label": "xs32110100_MSG0350",
      "style": 0,
      "name": "A man like you[ST:wide ]―[ST:wait ]"
    },
    {
      "$id": 38,
      "label": "xs32110100_MSG0360",
      "style": 0,
      "name": "Don't say it.[ST:wait ]"
    },
    {
      "$id": 39,
      "label": "xs32110100_MSG0370",
      "style": 0,
      "name": "But that girl[ST:wide ]―[ST:wait ]"
    },
    {
      "$id": 40,
      "label": "xs32110100_MSG0380",
      "style": 0,
      "name": "Lin...[ST:wait ]"
    },
    {
      "$id": 41,
      "label": "xs32110100_MSG0390",
      "style": 0,
      "name": "She told me that's what makes us human.[ST:wait ]"
    },
    {
      "$id": 42,
      "label": "xs32110100_MSG0400",
      "style": 0,
      "name": "Dirty and ugly.[ST:wait ]"
    },
    {
      "$id": 43,
      "label": "xs32110100_MSG0410",
      "style": 0,
      "name": "That's just how humans are[ST:wide ]―[ST:wait ]"
    },
    {
      "$id": 44,
      "label": "xs32110100_MSG0420",
      "style": 0,
      "name": "She's a kind kid[ST:wide ]―[ST:wait ]"
    },
    {
      "$id": 45,
      "label": "xs32110100_MSG0430",
      "style": 0,
      "name": "She tried to understand\nme until the very end[ST:wide ]―[ST:wait ]"
    },
    {
      "$id": 46,
      "label": "xs32110100_MSG0440",
      "style": 0,
      "name": "It's unbearable, isn't it?[ST:wait ]"
    },
    {
      "$id": 47,
      "label": "xs32110100_MSG0450",
      "style": 0,
      "name": "Making a child like her\nsay something like that[ST:wide ]―[ST:wait ]"
    },
    {
      "$id": 48,
      "label": "xs32110100_MSG0460",
      "style": 0,
      "name": "To think my despair[ST:wide ]―[ST:wait ]"
    },
    {
      "$id": 49,
      "label": "xs32110100_MSG0470",
      "style": 0,
      "name": "Caused her so much pain[ST:wide ]―[ST:wait ]"
    },
    {
      "$id": 50,
      "label": "xs32110100_MSG0480",
      "style": 0,
      "name": "Is that why you accepted death,[ST:wait ]"
    },
    {
      "$id": 51,
      "label": "xs32110100_MSG0485",
      "style": 0,
      "name": "and you're just lying around\nin a place like this?[ST:wait ]"
    },
    {
      "$id": 52,
      "label": "xs32110100_MSG0490",
      "style": 0,
      "name": "Yeah[ST:wide ]―[ST:wait ]"
    },
    {
      "$id": 53,
      "label": "xs32110100_MSG0500",
      "style": 0,
      "name": "I'm sure soon,[ST:wait ]"
    },
    {
      "$id": 54,
      "label": "xs32110100_MSG0510",
      "style": 0,
      "name": "I'll be able to see Sha-mei\nand Chenshi again.[ST:wait ]"
    },
    {
      "$id": 55,
      "label": "xs32110100_MSG0520",
      "style": 0,
      "name": "You might be satisfied with that, but[ST:wide ]―[ST:wait ]"
    },
    {
      "$id": 56,
      "label": "xs32110100_MSG0530",
      "style": 0,
      "name": "Not me.[ST:wait ]"
    },
    {
      "$id": 57,
      "label": "xs32110100_MSG0540",
      "style": 0,
      "name": "Even if this is the afterlife,[ST:wait ]"
    },
    {
      "$id": 58,
      "label": "xs32110100_MSG0550",
      "style": 0,
      "name": "I'm still going to live.[ST:wait ]"
    },
    {
      "$id": 59,
      "label": "xs32110100_MSG0560",
      "style": 0,
      "name": "I haven't finished protecting\nthe things I want to protect.[ST:wait ]"
    },
    {
      "$id": 60,
      "label": "xs32110100_MSG0570",
      "style": 0,
      "name": "Leaving behind unresolved feelings\nand just checking out by myself[ST:wide ]―[ST:wait ]"
    },
    {
      "$id": 61,
      "label": "xs32110100_MSG0580",
      "style": 0,
      "name": "No thanks.[ST:wait ]"
    },
    {
      "$id": 62,
      "label": "xs32110100_MSG0590",
      "style": 0,
      "name": "Right[ST:wide ]―[ST:wait ]"
    },
    {
      "$id": 63,
      "label": "xs32110100_MSG0600",
      "style": 0,
      "name": "That's exactly the kind of guy you are.[ST:wait ]"
    },
    {
      "$id": 64,
      "label": "xs32110100_MSG0610",
      "style": 0,
      "name": "Different from me.[ST:wait ]"
    },
    {
      "$id": 65,
      "label": "xs32110100_MSG0620",
      "style": 0,
      "name": "Go on now.[ST:wait ]"
    },
    {
      "$id": 66,
      "label": "xs32110100_MSG0630",
      "style": 0,
      "name": "You know the way, right?[ST:wait ]"
    },
    {
      "$id": 67,
      "label": "xs32110100_MSG0640",
      "style": 0,
      "name": "Yeah.[ST:wait ]"
    },
    {
      "$id": 68,
      "label": "xs32110100_MSG0650",
      "style": 0,
      "name": "I've got the best guide there is.[ST:wait ]"
    },
    {
      "$id": 69,
      "label": "xs32110100_MSG0660",
      "style": 0,
      "name": "The world I came from[ST:wide ]―[ST:wait ]"
    },
    {
      "$id": 70,
      "label": "xs32110100_MSG0670",
      "style": 0,
      "name": "It's a warm place.[ST:wait ]"
    },
    {
      "$id": 71,
      "label": "xs32110100_MSG0680",
      "style": 0,
      "name": "Everyone is waiting for your return.[ST:wait ]"
    },
    {
      "$id": 72,
      "label": "xs32110100_MSG0690",
      "style": 0,
      "name": "Hmph[ST:wide ]―[ST:wait ]"
    },
    {
      "$id": 73,
      "label": "xs32110100_MSG0700",
      "style": 0,
      "name": "I sure hope so.[ST:wait ]"
    },
    {
      "$id": 74,
      "label": "xs32110100_MSG0710",
      "style": 0,
      "name": "When you get back, pass a\nmessage to Lin for me.[ST:wait ]"
    },
    {
      "$id": 75,
      "label": "xs32110100_MSG0720",
      "style": 0,
      "name": "Humans are undoubtedly ugly.[ST:wait ]"
    },
    {
      "$id": 76,
      "label": "xs32110100_MSG0730",
      "style": 0,
      "name": "We cling to life, and\nsometimes trample others.[ST:wait ]"
    },
    {
      "$id": 77,
      "label": "xs32110100_MSG0740",
      "style": 0,
      "name": "But[ST:wide ]―[ST:wait ]"
    },
    {
      "$id": 78,
      "label": "xs32110100_MSG0750",
      "style": 0,
      "name": ""
    },
    {
      "$id": 79,
      "label": "xs32110100_MSG0760",
      "style": 0,
      "name": "If you are able to understand that,[ST:wait ]"
    },
    {
      "$id": 80,
      "label": "xs32110100_MSG0770",
      "style": 0,
      "name": "then that life isn't ugly at all.[ST:wait ]"
    },
    {
      "$id": 81,
      "label": "xs32110100_MSG0780",
      "style": 0,
      "name": "So, please live[ST:wide ]―[ST:wait ]"
    },
    {
      "$id": 82,
      "label": "xs32110100_MSG0790",
      "style": 0,
      "name": "Lao-san[ST:wide ]―[ST:wait ]"
    },
    {
      "$id": 83,
      "label": "xs32110100_MSG0800",
      "style": 0,
      "name": "I am not[ST:wide ]―[ST:wait ]"
    },
    {
      "$id": 84,
      "label": "xs32110100_MSG0810",
      "style": 0,
      "name": "Kind at all.[ST:wait ]"
    },
    {
      "$id": 85,
      "label": "xs32110100_MSG0820",
      "style": 0,
      "name": "Ultimately, trying to protect Lao-san[ST:wait ]"
    },
    {
      "$id": 86,
      "label": "xs32110100_MSG0830",
      "style": 0,
      "name": "was just because I didn't\nwant to feel sad anymore.[ST:wait ]"
    },
    {
      "$id": 87,
      "label": "xs32110100_MSG9010",
      "style": 0,
      "name": "This is the end, Lao.[ST:wait ]"
    },
    {
      "$id": 88,
      "label": "xs32110100_MSG9020",
      "style": 0,
      "name": "Stop it, Elma-san![ST:wait ]"
    },
    {
      "$id": 89,
      "label": "xs32110100_MSG9030",
      "style": 0,
      "name": "Move aside, Lin.[ST:wait ]"
    },
    {
      "$id": 90,
      "label": "xs32110100_MSG9040",
      "style": 0,
      "name": "We're comrades in BLADE, aren't we?![ST:wait ]"
    },
    {
      "$id": 91,
      "label": "xs32110100_MSG0840",
      "style": 0,
      "name": "I didn't[ST:wide ]―[ST:wait ]"
    },
    {
      "$id": 92,
      "label": "xs32110100_MSG0850",
      "style": 0,
      "name": "understand anything.[ST:wait ]"
    },
    {
      "$id": 93,
      "label": "xs32110100_MSG0860",
      "style": 0,
      "name": "I was just acting on\nchildish, immature emotions.[ST:wait ]"
    },
    {
      "$id": 94,
      "label": "xs32110100_MSG0870",
      "style": 0,
      "name": "[ST:wide ]―But,[ST:wait ]"
    },
    {
      "$id": 95,
      "label": "xs32110100_MSG0880",
      "style": 0,
      "name": "back then,[ST:wait ]"
    },
    {
      "$id": 96,
      "label": "xs32110100_MSG0890",
      "style": 0,
      "name": "you tried to protect\nLao-san, just like I did.[ST:wait ]"
    },
    {
      "$id": 97,
      "label": "xs32110100_MSG0900",
      "style": 0,
      "name": "If you hadn't done that,[ST:wait ]"
    },
    {
      "$id": 98,
      "label": "xs32110100_MSG0910",
      "style": 0,
      "name": "I might not have been able to stick to my\nconvictions, and I might have run away.[ST:wait ]"
    },
    {
      "$id": 99,
      "label": "xs32110100_MSG0920",
      "style": 0,
      "name": "I might have stayed a child to the very end.[ST:wait ]"
    },
    {
      "$id": 100,
      "label": "xs32110100_MSG0930",
      "style": 0,
      "name": "Yes.[ST:wait ]"
    },
    {
      "$id": 101,
      "label": "xs32110100_MSG0940",
      "style": 0,
      "name": "If you hadn't stood in the way back then[ST:wide ]―[ST:wait ]"
    },
    {
      "$id": 102,
      "label": "xs32110100_MSG0950",
      "style": 0,
      "name": "All of us would have ended\nup simply being ugly.[ST:wait ]"
    },
    {
      "$id": 103,
      "label": "xs32110100_MSG0960",
      "style": 0,
      "name": "You saved us from that despair.[ST:wait ]"
    },
    {
      "$id": 104,
      "label": "xs32110100_MSG0970",
      "style": 0,
      "name": "Logic doesn't matter here.[ST:wait ]"
    },
    {
      "$id": 105,
      "label": "xs32110100_MSG0980",
      "style": 0,
      "name": "There's no such thing as clean or\nugly when it comes to simply living.[ST:wait ]"
    },
    {
      "$id": 106,
      "label": "xs32110100_MSG0990",
      "style": 0,
      "name": "He told you to live.[ST:wait ]"
    },
    {
      "$id": 107,
      "label": "xs32110100_MSG1000",
      "style": 0,
      "name": "I made sure to deliver it.[ST:wait ]"
    },
    {
      "$id": 108,
      "label": "xs32110100_MSG1010",
      "style": 0,
      "name": "[ST:wide ]―Yes.[ST:wait ]"
    },
    {
      "$id": 109,
      "label": "xs32110100_MSG1020",
      "style": 0,
      "name": "Colonel Elma...![ST:wide ]―[ST:wait ]"
    },
    {
      "$id": 110,
      "label": "xs32110100_MSG1030",
      "style": 0,
      "name": "Help me[ST:wide ]―[ST:wait ]"
    },
    {
      "$id": 111,
      "label": "xs32110100_MSG1040",
      "style": 0,
      "name": "Gyaaaaah[ST:wide ]―[ST:wait ]"
    },
    {
      "$id": 112,
      "label": "xs32110100_MSG1050",
      "style": 0,
      "name": "What happened?![ST:wait ]"
    },
    {
      "$id": 113,
      "label": "xs32110100_MSG1060",
      "style": 0,
      "name": "What on earth is going on?![ST:wait ]"
    },
    {
      "$id": 114,
      "label": "xs32110100_MSG1070",
      "style": 0,
      "name": "Elma, that voice just now...[ST:wait ]"
    },
    {
      "$id": 115,
      "label": "xs32110100_MSG1080",
      "style": 0,
      "name": "Yes.[ST:wait ]"
    },
    {
      "$id": 116,
      "label": "xs32110100_MSG1090",
      "style": 0,
      "name": "That was the voice of a member\nfrom the unit earlier.[ST:wait ]"
    },
    {
      "$id": 117,
      "label": "xs32110100_MSG1100",
      "style": 0,
      "name": "I believe they said they were heading to\nthe Lakeview Stronghold in Yakou no Mori.[ST:wait ]"
    },
    {
      "$id": 118,
      "label": "xs32110100_MSG1110",
      "style": 0,
      "name": "Let's hurry.[ST:wait ]"
    },
    {
      "$id": 119,
      "label": "xs32110100_MSG1120",
      "style": 0,
      "name": "Yeah.[ST:wait ]"
    },
    {
      "$id": 120,
      "label": "xs32110100_MSG1130",
      "style": 0,
      "name": "I hope we make it in time[ST:wide ]―[ST:wait ]"
    }
  ]
}